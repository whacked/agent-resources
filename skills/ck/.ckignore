# .ckignore — managed by agent-resources (skills/ck/.ckignore)
# Installed to vault root by bootstrap.sh
# Syntax: same as .gitignore

# Data / config formats — too noisy for semantic search
*.edn
*.json
*.jsonl
*.yaml
*.yml

# Markup / rendered output
*.html

# Binary documents
*.pdf

# Images
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.svg
*.ico
*.webp
*.tiff

# Video
*.mp4
*.avi
*.mov
*.mkv
*.wmv
*.flv
*.webm

# Audio
*.mp3
*.wav
*.flac
*.aac
*.ogg
*.m4a

# Binary / compiled
*.exe
*.dll
*.so
*.dylib
*.a
*.lib
*.obj
*.o

# Archives
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
*.bz2
*.gz

# Databases
*.db
*.sqlite
*.sqlite3
*.parquet
*.arrow

# Office files
*.ppt
*.pptx
*.doc
*.docx
